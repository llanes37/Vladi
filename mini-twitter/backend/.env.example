# Variables de entorno para el backend
# Copiar este archivo a .env y ajustar los valores

# Puerto del servidor
PORT=3000

# URI de conexión a MongoDB
# Local: mongodb://localhost:27017/mini-twitter
# Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/mini-twitter
MONGODB_URI=mongodb://localhost:27017/mini-twitter

# Clave secreta para JWT (¡cambiar en producción!)
JWT_SECRET=tu_clave_secreta_super_segura_cambiar_en_produccion_2024

# Tiempo de expiración del token JWT
JWT_EXPIRES_IN=7d

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Entorno
NODE_ENV=development
